# App
PORT=4000

# Supabase (required for auth/JWT verification)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# PostgreSQL (required)
# Use ONE of these styles:
# 1) Single URL:
DATABASE_URL=postgresql://postgres:your_db_password@localhost:5432/devdiff
# 2) Individual fields (optional fallback for tooling/scripts):
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your_db_password
PGDATABASE=devdiff

# GitHub token (optional for ML dataset scripts; UI/API use per-user OAuth token)
GITHUB_TOKEN=ghp_your_personal_access_token

# LLM logic review (optional)
GROQ_API_KEY=gsk_your_groq_key
ENABLE_LOGIC_REVIEW=true

# ML settings
ML_MODEL_PATH=./ml/model.pkl
CONFIDENCE_THRESHOLD=65

# Seed script helper (required only when running: npm run seed)
SEED_USER_ID=00000000-0000-0000-0000-000000000000
