{
  "name": "devdiff-backend",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "node db/migrate.js",
    "seed": "node db/seed.js",
    "seed:append": "node db/seed.js",
    "train": "python3 ml/train.py",
    "prepare:labels": "node ml/prepare_labeling_data.js",
    "prepare:labels:priority": "node ml/prioritize_label_review.js",
    "train:real": "python3 ml/retrain_from_labels.py",
    "collect:prs": "node ml/collect_pr_dataset.js",
    "collect:prs:multi": "node ml/collect_pr_dataset.js",
    "collect:prs:snapshot": "set PR_DATASET_MERGE=false&& node ml/collect_pr_dataset.js",
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.js", "**/*.test.js"],
    "collectCoverageFrom": [
      "rules/**/*.js",
      "analysis/**/*.js",
      "db/**/*.js",
      "auth/**/*.js",
      "routes/**/*.js",
      "ml/**/*.js",
      "parser/**/*.js",
      "github/**/*.js",
      "reports/**/*.js",
      "intent/**/*.js",
      "!**/node_modules/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 50,
        "lines": 50,
        "statements": 50
      }
    }
  },
  "dependencies": {
    "@babel/parser": "^7.28.4",
    "@supabase/supabase-js": "^2.49.1",
    "axios": "^1.6.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "pg": "^8.13.1",
    "uuid": "^9.0.0",
    "web-tree-sitter": "^0.22.2",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "jest": "^30.4.2",
    "nodemon": "^3.0.3"
  }
}
